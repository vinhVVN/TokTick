<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="20dp"
    android:background="@drawable/bg_bottom_sheet">

    <!-- Top: Task Title Input -->
    <EditText
        android:id="@+id/etTaskTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Nhập tên công việc..."
        android:background="@null"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/text_main_light"
        android:importantForAutofill="no"
        android:inputType="textCapSentences"
        android:paddingVertical="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Selection Area: Time, Category, Tags -->
    <LinearLayout
        android:id="@+id/llSelections"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/etTaskTitle">

        <TextView
            android:id="@+id/tvSelectTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hôm nay, 18:00"
            android:textSize="14sp"
            android:textColor="@color/text_muted_light"
            android:padding="4dp"
            android:background="?attr/selectableItemBackground" />

        <Spinner
            android:id="@+id/spinnerCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipSelectTags"
            style="@style/Widget.MaterialComponents.Chip.Action"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Tag"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- Middle: Subtasks Area -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSubtasksInput"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:layout_marginTop="8dp"
        app:layout_constrainedHeight="true"
        app:layout_constraintHeight_max="160dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/llSelections"
        app:layout_constraintBottom_toTopOf="@id/llBottomToolbar"
        app:layout_constraintVertical_bias="0" />

    <!-- Bottom: Toolbar -->
    <LinearLayout
        android:id="@+id/llBottomToolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/rvSubtasksInput">

        <ImageView
            android:id="@+id/btnAddSubtaskItem"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@drawable/ic_add"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Thêm danh sách con"
            app:tint="@color/text_muted_light" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Nút Lưu -->
        <ImageView
            android:id="@+id/btnSaveTask"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_send"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Lưu công việc"
            app:tint="@color/primary_text" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
