<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingVertical="4dp">

    <CheckBox
        android:id="@+id/cbSubtask"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:buttonTint="@color/primary_text" />

    <EditText
        android:id="@+id/etSubtaskTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="@null"
        android:hint="Tên bước nhỏ..."
        android:inputType="text"
        android:paddingHorizontal="8dp"
        android:textColor="@color/text_main_light"
        android:textSize="16sp" />

    <ImageView
        android:id="@+id/btnDeleteSubtask"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Xóa"
        android:padding="6dp"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        app:tint="@color/text_muted_light" />

</LinearLayout>